{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Traffic Controller",
  "version": "0.1.0",
  "identifier": "com.aitc.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "visible": true,
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 800,
        "decorations": true,
        "title": "AI Traffic Controller"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
